---
import '../styles/global.css';
import type { CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'tips'>;
};

const { post } = Astro.props;
const { title, description } = post.data || {};
const { Content } = await post.render();
const pubDate = new Date(post.data.pubDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const tags = post.data.tags || [];
const image = post.data.image || '';
---

<!-- Blog Article -->
<article class="mx-auto max-w-3xl px-4 pt-6 pb-12 sm:px-6 lg:px-8 lg:pt-10">
  <div class="max-w-2xl">
    <!-- Avatar Media -->
    <div class="mb-6 flex items-center justify-between">
      <div class="flex w-full gap-x-5 sm:items-center sm:gap-x-3">
        <div class="shrink-0">
          <img
            class="size-12 rounded-full"
            src="https://images.unsplash.com/photo-1669837401587-f9a4cfe3126e?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80"
            alt="Avatar"
          />
        </div>

        <div class="grow">
          <div class="flex items-center justify-between gap-x-2">
            <div>
              <!-- Tooltip -->
              <div
                class="hs-tooltip inline-block [--placement:bottom] [--trigger:hover]"
              >
                <div
                  class="hs-tooltip-toggle block cursor-pointer text-start sm:mb-1"
                >
                  <span class="text-foreground font-semibold">
                    Leyla Ludic
                  </span>

                  <!-- Dropdown Card -->
                  <div
                    class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible bg-popover border-popover-line divide-popover-line invisible absolute z-10 inline-block max-w-xs cursor-default divide-y rounded-xl border opacity-0 shadow-lg transition-opacity"
                    role="tooltip"
                  >
                    <!-- Body -->
                    <div class="p-4 sm:p-5">
                      <div
                        class="mb-2 flex w-full gap-x-5 sm:items-center sm:gap-x-3"
                      >
                        <div class="shrink-0">
                          <img
                            class="size-8 rounded-full"
                            src="https://images.unsplash.com/photo-1669837401587-f9a4cfe3126e?ixlib=rb-4.0.3&ixid=MnwxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8&auto=format&fit=facearea&facepad=2&w=320&h=320&q=80"
                            alt="Avatar"
                          />
                        </div>

                        <div class="grow">
                          <p class="text-foreground text-lg font-semibold">
                            Leyla Ludic
                          </p>
                        </div>
                      </div>
                      <p class="text-muted-foreground-1 text-sm">
                        Leyla is a Customer Success Specialist at Preline and
                        spends her time speaking to in-house recruiters all over
                        the world.
                      </p>
                    </div>
                    <!-- End Body -->

                    <!-- Footer -->
                    <div
                      class="flex items-center justify-between px-4 py-3 sm:px-5"
                    >
                      <ul class="space-x-3 text-xs">
                        <li class="inline-block">
                          <span class="text-foreground font-semibold">56</span>
                          <span class="text-muted-foreground">articles</span>
                        </li>
                        <li class="inline-block">
                          <span class="text-foreground font-semibold">1k+</span>
                          <span class="text-muted-foreground">followers</span>
                        </li>
                      </ul>

                      <div>
                        <button
                          type="button"
                          class="bg-primary border-primary-line text-primary-foreground hover:bg-primary-hover focus:bg-primary-focus inline-flex cursor-pointer items-center gap-x-2 rounded-lg border px-2.5 py-1.5 text-xs font-medium focus:outline-hidden disabled:pointer-events-none disabled:opacity-50"
                        >
                          <svg
                            class="size-3.5 shrink-0"
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            fill="currentColor"
                            viewBox="0 0 16 16"
                          >
                            <path
                              d="M1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm5-6a3 3 0 1 0 0-6 3 3 0 0 0 0 6z"
                            ></path>
                            <path
                              fill-rule="evenodd"
                              d="M13.5 5a.5.5 0 0 1 .5.5V7h1.5a.5.5 0 0 1 0 1H14v1.5a.5.5 0 0 1-1 0V8h-1.5a.5.5 0 0 1 0-1H13V5.5a.5.5 0 0 1 .5-.5z"
                            ></path>
                          </svg>
                          Follow
                        </button>
                      </div>
                    </div>
                    <!-- End Footer -->
                  </div>
                  <!-- End Dropdown Card -->
                </div>
              </div>
              <!-- End Tooltip -->

              <ul class="text-muted-foreground-1 text-xs">
                <time
                  datetime={pubDate}
                  class="before:bg-surface-2 relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full last:pe-0 last-of-type:before:hidden"
                >
                  {pubDate}
                </time>
                <li
                  class="before:bg-surface-2 relative inline-block pe-6 before:absolute before:end-2 before:top-1/2 before:size-1 before:-translate-y-1/2 before:rounded-full last:pe-0 last-of-type:before:hidden"
                >
                  {
                    tags.length > 0 && (
                      <div class="mt-4 flex flex-wrap gap-1">
                        {tags.map((tag: string) => (
                          <span class="rounded-full bg-purple-100 px-2.5 py-0.5 text-xs whitespace-nowrap text-purple-600">
                            {tag}
                          </span>
                        ))}
                      </div>
                    )
                  }
                </li>
              </ul>
            </div>

            <!-- Button Group -->
            <div>
              <button
                type="button"
                class="bg-layer border-layer-line text-layer-foreground hover:bg-layer-hover focus:bg-layer-focus inline-flex cursor-pointer items-center gap-x-2 rounded-lg border px-2.5 py-1.5 text-sm font-medium shadow-2xs focus:outline-hidden disabled:pointer-events-none disabled:opacity-50"
              >
                <svg
                  class="size-3.5"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  fill="currentColor"
                  viewBox="0 0 16 16"
                >
                  <path
                    d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
                  ></path>
                </svg>
                Tweet
              </button>
            </div>
            <!-- End Button Group -->
          </div>
        </div>
      </div>
    </div>
    <!-- End Avatar Media -->

    <!-- Content -->
    <div class="space-y-5 md:space-y-8">
      <div class="space-y-3">
        <h2 class="text-foreground text-2xl font-bold md:text-3xl">{title}</h2>
        <figure>
          <img
            class="w-full rounded-xl object-cover"
            src={image}
            alt="Blog Image"
          />
          <figcaption class="text-muted-foreground-1 mt-3 text-center text-sm">
            {title}
          </figcaption>
        </figure>

        <slot />
        <!-- End Content -->
      </div>
    </div>
    <!-- End Blog Article -->

    <!-- Sticky Share Group -->
    <div class="sticky inset-x-0 bottom-6 text-center">
      <div class="bg-layer inline-block rounded-full px-4 py-3 shadow-md">
        <div class="flex items-center gap-x-1.5">
          <!-- Button -->
          <div class="hs-tooltip inline-block">
            <button
              type="button"
              class="hs-tooltip-toggle text-muted-foreground-1 hover:text-foreground focus:text-foreground flex items-center gap-x-2 text-sm focus:outline-hidden"
            >
              <svg
                class="size-4 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path
                  d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"
                ></path></svg
              >
              875
              <span
                class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible bg-tooltip border-tooltip-line text-tooltip-foreground invisible absolute z-10 inline-block rounded-md border px-2 py-1 text-xs font-medium opacity-0 shadow-2xs transition-opacity"
                role="tooltip"
              >
                Like
              </span>
            </button>
          </div>
          <!-- Button -->

          <div class="border-line-3 mx-3 block h-3 border-e"></div>

          <!-- Button -->
          <div class="hs-tooltip inline-block">
            <button
              type="button"
              class="hs-tooltip-toggle text-muted-foreground-1 hover:text-foreground focus:text-foreground flex items-center gap-x-2 text-sm focus:outline-hidden"
            >
              <svg
                class="size-4 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="m3 21 1.9-5.7a8.5 8.5 0 1 1 3.8 3.8z"></path></svg
              >
              16
              <span
                class="hs-tooltip-content hs-tooltip-shown:opacity-100 hs-tooltip-shown:visible bg-tooltip border-tooltip-line text-tooltip-foreground invisible absolute z-10 inline-block rounded-md border px-2 py-1 text-xs font-medium opacity-0 shadow-2xs transition-opacity"
                role="tooltip"
              >
                Comment
              </span>
            </button>
          </div>
          <!-- Button -->

          <div class="border-line-3 mx-3 block h-3 border-e"></div>

          <!-- Button -->
          <div class="hs-dropdown relative inline-flex">
            <button
              id="hs-blog-article-share-dropdown"
              type="button"
              class="text-muted-foreground-1 hover:text-foreground focus:text-foreground flex items-center gap-x-2 text-sm focus:outline-hidden"
              aria-haspopup="menu"
              aria-expanded="false"
              aria-label="Dropdown"
            >
              <svg
                class="size-4 shrink-0"
                xmlns="http://www.w3.org/2000/svg"
                width="24"
                height="24"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"
                ></path><polyline points="16 6 12 2 8 6"></polyline><line
                  x1="12"
                  x2="12"
                  y1="2"
                  y2="15"></line></svg
              >
              Share
            </button>
            <div
              class="hs-dropdown-menu duration hs-dropdown-open:opacity-100 bg-dropdown border-dropdown-line z-10 mb-1 hidden w-56 rounded-xl border p-2 opacity-0 shadow-md transition-[opacity,margin]"
              role="menu"
              aria-orientation="vertical"
              aria-labelledby="hs-blog-article-share-dropdown"
            >
              <a
                class="text-dropdown-item-foreground hover:bg-dropdown-item-hover focus:bg-dropdown-item-focus flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-sm focus:outline-hidden"
                href="#"
              >
                <svg
                  class="size-4 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="24"
                  height="24"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
                  ></path><path
                    d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
                  ></path></svg
                >
                Copy link
              </a>
              <div class="border-dropdown-divider my-2 border-t"></div>
              <a
                class="text-dropdown-item-foreground hover:bg-dropdown-item-hover focus:bg-dropdown-item-focus flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-sm focus:outline-hidden"
                href="#"
              >
                <svg
                  class="size-4 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  fill="currentColor"
                  viewBox="0 0 16 16"
                >
                  <path
                    d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
                  ></path>
                </svg>
                Share on Twitter
              </a>
              <a
                class="text-dropdown-item-foreground hover:bg-dropdown-item-hover focus:bg-dropdown-item-focus flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-sm focus:outline-hidden"
                href="#"
              >
                <svg
                  class="size-4 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  fill="currentColor"
                  viewBox="0 0 16 16"
                >
                  <path
                    d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951z"
                  ></path>
                </svg>
                Share on Facebook
              </a>
              <a
                class="text-dropdown-item-foreground hover:bg-dropdown-item-hover focus:bg-dropdown-item-focus flex items-center gap-x-3.5 rounded-lg px-3 py-2 text-sm focus:outline-hidden"
                href="#"
              >
                <svg
                  class="size-4 shrink-0"
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  fill="currentColor"
                  viewBox="0 0 16 16"
                >
                  <path
                    d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854V1.146zm4.943 12.248V6.169H2.542v7.225h2.401zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248-.822 0-1.359.54-1.359 1.248 0 .694.521 1.248 1.327 1.248h.016zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016a5.54 5.54 0 0 1 .016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225h2.4z"
                  ></path>
                </svg>
                Share on LinkedIn
              </a>
            </div>
          </div>
          <!-- Button -->
        </div>
      </div>
    </div>
    <!-- End Sticky Share Group -->
  </div>
</article>
